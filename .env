# LLM Provider Configuration
# Options: "local" (uses Ollama), "openai", "anthropic"
MODEL_PROVIDER=local

# Ollama Configuration
# For Docker containers: use http://host.docker.internal:11434
# For local development on Windows/Mac/Linux: use localhost or 127.0.0.1
OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_MODEL_NAME=qwen2.5:7b

# Set to true to verify Ollama is running
VERIFY_OLLAMA_ON_START=false

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Tesseract OCR Path (Windows)
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# Project Settings
MAX_TOKENS=4000
TEMPERATURE=0.3
CHUNK_SIZE=2000
